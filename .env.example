# ─── ProductClank backend ──────────────────────────────────────────────────
PRODUCTCLANK_API_URL=https://api.productclank.com/api/v1
PRODUCTCLANK_WEBAPP_URL=https://app.productclank.com
# Trusted connector agent key (server secret — never exposed to Claude or users)
PRODUCTCLANK_TRUSTED_KEY=pck_live_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── MCP server / OAuth issuer (public HTTPS URL) ───────────────────────────
PORT=3100
MCP_SERVER_URL=https://mcp.productclank.com
OAUTH_ISSUER=https://mcp.productclank.com

# ─── Supabase (shared ProductClank prod DB; service role) ───────────────────
SUPABASE_URL=https://fimvgmceguupqdtdenol.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Shared HS256 secret for the webapp → MCP connect grant ─────────────────
# Must match MCP_GRANT_SECRET set in the ProductClank webapp env.
MCP_GRANT_SECRET=generate-a-long-random-string

# ─── Optional token lifetimes (seconds) ────────────────────────────────────
# ACCESS_TOKEN_TTL_SECONDS=3600
# REFRESH_TOKEN_TTL_SECONDS=2592000
